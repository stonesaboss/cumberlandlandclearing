# ─── Upper Cumberland Land Clearing — environment variables ───
# Copy to `.env` for local Astro dev and `.dev.vars` for `wrangler pages dev`.
# NEVER commit real values. Names only in this file.

# Canonical production URL (also set in Cloudflare Pages build env, prod + preview)
PUBLIC_SITE_URL=

# Cloudflare Turnstile — site key is browser-safe (also the committed fallback
# in src/components/LeadForm.astro); secret key is server-only, never commit it.
PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAD0-2TnxP2Vp7Ht6
TURNSTILE_SECRET_KEY=

# Lead delivery (server-side, set as encrypted Cloudflare secrets)
LEAD_WEBHOOK_URL=
LEAD_WEBHOOK_SECRET=
FORM_RECIPIENT_EMAIL=
EMAIL_API_KEY=

# Analytics (browser-safe; the GA4 ID below is also the committed fallback in
# src/config.ts — setting PUBLIC_TAG_MANAGER_ID switches to GTM instead)
PUBLIC_ANALYTICS_ID=G-6NBXC4SXPG
PUBLIC_TAG_MANAGER_ID=

# Local development safety switch — when "true", the lead endpoint labels
# submissions as TEST and skips webhook/email delivery.
DEV_MODE=
