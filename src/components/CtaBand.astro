---
import { SITE } from '../config';

interface Props {
  heading?: string;
  copy?: string;
  primaryLabel?: string;
}
const {
  heading = 'Ready to Turn Overgrown Land Into Usable Property?',
  copy = 'Tell us where the property is located, how much land is involved, what needs to be cleared and how you plan to use the property.',
  primaryLabel = 'Submit Property Details',
} = Astro.props;
---

<section class="section section--dark cta-band">
  <div class="container cta-inner">
    <h2>{heading}</h2>
    <p>{copy}</p>
    <div class="cta-actions">
      <a class="btn btn-orange btn-lg" href="/request-estimate/" data-track="request_estimate_click" data-track-label="cta_band">{primaryLabel}</a>
      <a class="btn btn-outline-light btn-lg" href={`tel:${SITE.phoneTel}`} data-track="phone_click" data-track-label="cta_band">Call {SITE.phoneDisplay}</a>
    </div>
  </div>
</section>

<style>
  .cta-band {
    background:
      linear-gradient(rgba(15, 45, 24, 0.92), rgba(15, 45, 24, 0.92)),
      url('/images/other/cta-forestry-mulcher-background.webp') center/cover no-repeat;
    text-align: center;
  }
  .cta-inner { max-width: 760px; }
  .cta-inner p { color: #cfd6c5; font-size: 1.05rem; }
  .cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }
</style>
