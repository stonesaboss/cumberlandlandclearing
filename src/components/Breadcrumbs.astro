---
interface Props {
  crumbs: { label: string; href: string }[];
}
const { crumbs } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <div class="container">
    <ol>
      {crumbs.map((c, i) =>
        i === crumbs.length - 1 ? (
          <li aria-current="page">{c.label}</li>
        ) : (
          <li><a href={c.href}>{c.label}</a></li>
        ),
      )}
    </ol>
  </div>
</nav>
