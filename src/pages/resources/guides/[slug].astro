---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import ResourcePageHeader from '../../../components/ResourcePageHeader.astro';
import ResourceFeatureImage from '../../../components/ResourceFeatureImage.astro';
import FaqAccordion from '../../../components/FaqAccordion.astro';
import HelpfulGuides from '../../../components/HelpfulGuides.astro';
import CtaBand from '../../../components/CtaBand.astro';
import { guides, type Guide } from '../../../data/guides';
import { resolveImage } from '../../../data/resources';
import { breadcrumbSchema, faqSchema } from '../../../lib/schema';

export function getStaticPaths() {
  return guides.map((guide) => ({ params: { slug: guide.slug }, props: { guide } }));
}

interface Props {
  guide: Guide;
}
const { guide } = Astro.props;
const siteUrl = (Astro.site?.href ?? '').replace(/\/$/, '');

const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Land Clearing Resources', href: '/resources/' },
  { label: guide.hubLabel, href: `/resources/${guide.hub}/` },
  { label: guide.h1, href: `/resources/guides/${guide.slug}/` },
];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: guide.h1,
  description: guide.metaDescription,
  datePublished: guide.datePublished,
  dateModified: guide.datePublished,
  author: { '@type': 'Organization', name: 'Cumberland Land Clearing Editorial Team' },
  mainEntityOfPage: `${siteUrl}/resources/guides/${guide.slug}/`,
};

const schema = [
  breadcrumbSchema(siteUrl, crumbs),
  articleSchema,
  ...(guide.faqs.length ? [faqSchema(guide.faqs)] : []),
];
---

<BaseLayout
  title={guide.metaTitle}
  description={guide.metaDescription}
  schema={schema}
  ogImage={resolveImage(guide.image)}
>
  <Breadcrumbs crumbs={crumbs} />
  <ResourcePageHeader eyebrow={guide.eyebrow} h1={guide.h1} />

  <div class="container guide-body section">
    <ResourceFeatureImage image={guide.image} loading="eager" />

    {guide.intro.map((para) => (
      <p class="lead-para">{para}</p>
    ))}

    {guide.sections.map((s) => (
      <section class="content-section">
        <h2>{s.heading}</h2>
        {s.paragraphs?.map((para) => <p>{para}</p>)}
        {s.bullets && (
          <ul>
            {s.bullets.map((b) => <li>{b}</li>)}
          </ul>
        )}
      </section>
    ))}

    <section class="content-section related-links">
      <h2>Related Services and Areas</h2>
      <ul>
        {guide.related.map((r) => (
          <li><a href={r.href}>{r.label}</a></li>
        ))}
      </ul>
    </section>

    {guide.resources && guide.resources.length > 0 && <HelpfulGuides links={guide.resources} />}

    <p class="disclosure-note">
      This guide is general information for property owners and does not replace an on-site
      evaluation. Upper Cumberland Land Clearing is an independent referral service; project scope,
      methods, equipment, pricing and scheduling are determined by the contractor who reviews your
      property.
    </p>
  </div>

  {guide.faqs.length > 0 && <FaqAccordion faqs={guide.faqs} heading={`${guide.hubLabel} Questions`} />}

  <CtaBand />
</BaseLayout>

<style>
  .guide-body { max-width: 900px; }
  .lead-para { font-size: 1.08rem; }
  .guide-body :global(.resource-feature) { margin-bottom: 1.5rem; }
  .content-section { margin-top: 1.75rem; }
  .related-links ul { list-style: none; padding: 0; margin: 0; }
  .related-links li { margin-bottom: 0.4rem; }
  .related-links a { font-weight: 600; }
  .guide-body .disclosure-note { margin-top: 2rem; }
</style>
