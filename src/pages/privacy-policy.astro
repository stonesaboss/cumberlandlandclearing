---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE } from '../config';
import { breadcrumbSchema } from '../lib/schema';

const title = 'Privacy Policy | Upper Cumberland Land Clearing';
const description =
  'Privacy policy for Upper Cumberland Land Clearing: what information is collected through project-request forms, how it is used, shared and retained.';

const siteUrl = (Astro.site?.href ?? '').replace(/\/$/, '');
const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Privacy Policy', href: '/privacy-policy/' },
];
---

<BaseLayout title={title} description={description} schema={[breadcrumbSchema(siteUrl, crumbs)]}>
  <Breadcrumbs crumbs={crumbs} />
  <section class="section">
    <div class="container legal-wrap">
      <h1>Privacy Policy</h1>
      <p><em>Last updated: July 2026</em></p>

      <h2>Information We Collect</h2>
      <p>When you submit a project request, we collect the information you provide:</p>
      <ul>
        <li>Contact details: name, phone number, email address</li>
        <li>Property details: location, city or county, acreage, condition, terrain, access, intended use and project description</li>
        <li>Photographs you choose to upload</li>
        <li>Technical details necessary to process the submission, such as the page the form was submitted from</li>
      </ul>
      <p>
        The website may also use analytics tools that collect standard usage data (pages viewed,
        approximate location, device type) to understand how the site is used.
      </p>

      <h2>How We Use It</h2>
      <ul>
        <li>To review and respond to your project request</li>
        <li>To share the request with one or more local contractors so they can evaluate and respond to it (see the <a href="/referral-disclosure/">referral disclosure</a>)</li>
        <li>To operate, secure and improve the website</li>
      </ul>

      <h2>Sharing</h2>
      <p>
        Project requests may be shared with independent local contractors for the purpose of
        responding to your request. We do not sell your personal information. Service providers
        that host this website, deliver email or provide spam protection process data on our
        behalf.
      </p>

      <h2>Photo Uploads</h2>
      <p>
        Uploaded photographs are stored privately and used only to evaluate and route your project
        request. They are not published without permission.
      </p>

      <h2>Retention and Deletion</h2>
      <p>
        Request details are retained as long as needed to handle the request and for reasonable
        record-keeping. You may request deletion of your submitted information at any time using
        the details on the <a href="/contact/">contact page</a> or by emailing
        <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
      </p>

      <h2>Cookies and Analytics</h2>
      <p>
        The site may use analytics cookies to measure usage. Your browser settings can limit or
        block cookies; the site remains usable without them.
      </p>

      <h2>Contact</h2>
      <p>
        Questions about this policy: <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .legal-wrap { max-width: 760px; }
  h2 { margin-top: 1.75rem; }
</style>
