---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadForm from '../components/LeadForm.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import CtaBand from '../components/CtaBand.astro';
import ServiceAreaMap from '../components/ServiceAreaMap.astro';
import { SITE, PROCESS_DISCLOSURE } from '../config';
import { homeFaqs } from '../data/faqs';
import { faqSchema } from '../lib/schema';

const title = 'Land Clearing & Forestry Mulching | Upper Cumberland TN';
const description =
  'Request land clearing, forestry mulching, brush clearing, lot clearing and acreage-clearing services in Cookeville, Crossville and Upper Cumberland, Tennessee.';

const services = [
  {
    name: 'Land Clearing',
    copy: 'Clear trees, brush and unwanted vegetation for property access, construction, farming, development or land improvement.',
    link: 'Land Clearing in Cookeville',
    href: '/land-clearing-cookeville-tn/',
    img: '/images/wooded-lot-clearing.svg',
    alt: 'Illustration of trees and brush being cleared from a wooded property',
  },
  {
    name: 'Forestry Mulching',
    copy: 'Reduce dense brush, saplings and unwanted vegetation into ground-level mulch with less hauling and fewer debris piles.',
    link: 'Forestry Mulching in Cookeville',
    href: '/forestry-mulching-cookeville-tn/',
    img: '/images/forestry-mulching.svg',
    alt: 'Illustration of a tracked forestry mulcher grinding brush into mulch',
  },
  {
    name: 'Brush Clearing',
    copy: 'Reclaim overgrown property, improve visibility and create access through dense brush, vines, saplings and undergrowth.',
    link: 'Brush Clearing in Cookeville',
    href: '/brush-clearing-cookeville-tn/',
    img: '/images/brush-clearing.svg',
    alt: 'Illustration of dense brush being cleared from an overgrown parcel',
  },
  {
    name: 'Lot Clearing',
    copy: 'Prepare residential and rural lots for building, utilities, access roads, property improvements or future use.',
    link: 'Lot Clearing in Cookeville',
    href: '/lot-clearing-cookeville-tn/',
    img: '/images/building-site-preparation.svg',
    alt: 'Illustration of a residential lot cleared for construction',
  },
  {
    name: 'Grading & Site Preparation',
    copy: 'Request clearing and related preparation for construction areas, driveways, drainage work and usable ground.',
    link: 'Excavation, Grading & Site Prep',
    href: '/excavation-grading-site-prep/',
    img: '/images/grading-site-prep.svg',
    alt: 'Illustration of a graded building pad and driveway on cleared ground',
  },
];

const projectTypes = [
  {
    name: 'Building-Site Preparation',
    copy: 'Clear and prepare the footprint for a home, cabin, barn or shop — including access for construction traffic.',
    href: '/lot-clearing-cookeville-tn/',
  },
  {
    name: 'Overgrown Acreage Recovery',
    copy: 'Open up parcels that have grown shut with brush and saplings so the land can be walked, used and maintained.',
    href: '/brush-clearing-cookeville-tn/',
  },
  {
    name: 'Pasture Reclamation',
    copy: 'Push cedar, briars and encroaching brush back off the field and return the ground to grazing or hay.',
    href: '/pasture-reclamation/',
  },
  {
    name: 'Fence-Line Clearing',
    copy: 'Clear corridors along boundaries and farm fencing so fence can be inspected, repaired or replaced.',
    href: '/fence-line-clearing/',
  },
  {
    name: 'Trail & Access Clearing',
    copy: 'Cut trails and interior access routes through wooded ground for recreation, hunting and land management.',
    href: '/trail-clearing/',
  },
  {
    name: 'Pond-Site Clearing',
    copy: 'Clear vegetation, stumps and access around a planned pond footprint before excavation begins.',
    href: '/pond-excavation/',
  },
  {
    name: 'Hunting-Property Access',
    copy: 'Open shooting lanes, stand access and food-plot areas without stripping the cover that makes the ground hunt.',
    href: '/trail-clearing/',
  },
  {
    name: 'Farm & Rural Property Improvement',
    copy: 'General clearing that keeps a rural property usable — edges, lanes, old home sites and problem corners.',
    href: '/land-clearing-cookeville-tn/',
  },
];

const acreageServices = [
  {
    name: 'Pasture Reclamation',
    copy: 'Recover usable pasture from brush, saplings and encroaching vegetation.',
    href: '/pasture-reclamation/',
  },
  {
    name: 'Fence-Line Clearing',
    copy: 'Restore visibility and access around property boundaries, agricultural fencing and utility corridors.',
    href: '/fence-line-clearing/',
  },
  {
    name: 'Trail Clearing',
    copy: 'Create or reopen trails for property access, hunting, recreation and land management.',
    href: '/trail-clearing/',
  },
  {
    name: 'Stump & Tree Clearing',
    copy: 'Request removal or clearing of unwanted trees, roots and stumps when the project requires more than surface mulching.',
    href: '/stump-and-tree-clearing/',
  },
  {
    name: 'Pond-Site Clearing',
    copy: 'Clear access and vegetation around planned pond sites before excavation or construction work begins.',
    href: '/pond-excavation/',
  },
];

const gallery = [
  { label: 'Overgrown Acreage', img: '/images/overgrown-acreage.svg', alt: 'Illustration of rural acreage overtaken by dense brush and volunteer trees' },
  { label: 'Forestry Mulching', img: '/images/forestry-mulching.svg', alt: 'Illustration of a tracked forestry mulcher clearing dense brush on rural acreage' },
  { label: 'Wooded Lot Clearing', img: '/images/wooded-lot-clearing.svg', alt: 'Illustration of a wooded lot being cleared for use' },
  { label: 'Pasture Reclamation', img: '/images/pasture-reclamation.svg', alt: 'Illustration of pasture ground being recovered from brush encroachment' },
  { label: 'Fence-Line Clearing', img: '/images/fence-line-clearing.svg', alt: 'Illustration of a cleared corridor along a farm fence line' },
  { label: 'Trail Access', img: '/images/trail-access.svg', alt: 'Illustration of a cleared access trail through wooded property' },
  { label: 'Building-Site Preparation', img: '/images/building-site-preparation.svg', alt: 'Illustration of a cleared and prepared building site' },
  { label: 'Pond-Site Clearing', img: '/images/pond-site-clearing.svg', alt: 'Illustration of a cleared pond site with open banks' },
];

const checklist = [
  'Property address or nearest road',
  'Estimated acreage',
  'Trees, saplings, brush or mixed vegetation',
  'Flat, sloped, rocky or wet terrain',
  'Equipment access width',
  'Gates, fences or structures',
  'Overhead or underground utilities',
  'Desired material handling',
  'Intended property use after clearing',
  'Target project date',
  'Known drainage concerns',
  'Photographs or video of the property',
];

const schema = [faqSchema(homeFaqs)];
---

<BaseLayout title={title} description={description} schema={schema}>
  <!-- 1 · HERO -->
  <section class="hero">
    <div class="hero-media" aria-hidden="true"></div>
    <div class="container hero-inner">
      <div class="hero-copy">
        <p class="hero-eyebrow">Upper Cumberland Property Clearing</p>
        <h1>
          <span class="hero-h1-main">Land Clearing &<br />Forestry Mulching</span>
          <span class="hero-h1-sub">in Upper Cumberland</span>
        </h1>
        <p class="hero-text">
          Request clearing for overgrown acreage, wooded lots, pastures, fence lines, trails,
          building sites and rural property throughout Cookeville and the Upper Cumberland region.
        </p>
        <div class="hero-actions">
          <a class="btn btn-orange btn-lg" href="/request-estimate/" data-track="request_estimate_click" data-track-label="hero">Request a Project Review</a>
          <a class="btn btn-outline-light btn-lg" href={`tel:${SITE.phoneTel}`} data-track="phone_click" data-track-label="hero">Call {SITE.phoneDisplay}</a>
        </div>
      </div>
    </div>
    <div class="hero-points">
      <div class="container hero-points-inner">
        <span>Residential &amp; Rural Acreage</span>
        <span>Brush, Trees &amp; Overgrowth</span>
        <span>Lots, Trails, Pastures &amp; Site Prep</span>
      </div>
    </div>
  </section>

  <!-- 2 · QUICK QUALIFICATION BAR -->
  <section class="qual-bar" aria-label="Quick project questions">
    <div class="container qual-inner">
      <ul class="qual-questions">
        <li>Where is the property?</li>
        <li>How many acres?</li>
        <li>What needs to be cleared?</li>
        <li>When do you want to begin?</li>
      </ul>
      <a class="btn btn-orange" href="#home-form" data-track="request_estimate_click" data-track-label="qual_bar">Tell Us About the Property</a>
    </div>
  </section>

  <div class="container home-grid">
    <div class="home-main">
      <!-- 3 · CORE SERVICE CARDS -->
      <section class="section" id="services">
        <div class="section-heading">
          <h2>Land-Clearing Services for Upper Cumberland Properties</h2>
          <p>
            Explore clearing options for rural acreage, homesites, farms, wooded lots, overgrown
            property and future construction.
          </p>
        </div>
        <div class="service-cards">
          {services.map((s) => (
            <article class="card service-card">
              <img src={s.img} alt={s.alt} width="400" height="230" loading="lazy" />
              <div class="service-card-body">
                <h3>{s.name}</h3>
                <p>{s.copy}</p>
                <a href={s.href}>{s.link} →</a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <!-- Mobile-only inline form placement, immediately after service cards -->
      <div class="mobile-form" id="home-form">
        <LeadForm idPrefix="home-m" />
      </div>

      <!-- 4 · PROJECT TYPES -->
      <section class="section section--cream project-types" id="project-types">
        <div class="section-heading">
          <h2>What Are You Clearing the Property For?</h2>
        </div>
        <div class="type-grid">
          {projectTypes.map((t) => (
            <a class="card type-card" href={t.href}>
              <h3>{t.name}</h3>
              <p>{t.copy}</p>
            </a>
          ))}
        </div>
      </section>

      <!-- 5 · COMPARISON -->
      <section class="section" id="comparison">
        <div class="section-heading">
          <h2>Land Clearing or Forestry Mulching: Which Fits Your Property?</h2>
        </div>
        <div class="compare-grid">
          <div class="compare-col">
            <h3>Traditional Land Clearing</h3>
            <ul>
              <li>Better suited for larger tree removal</li>
              <li>May include stump or root removal</li>
              <li>Often used for construction preparation</li>
              <li>Can support major grading or excavation</li>
              <li>May involve hauling or complete material removal</li>
            </ul>
          </div>
          <div class="compare-col compare-col--alt">
            <h3>Forestry Mulching</h3>
            <ul>
              <li>Well suited for brush and saplings</li>
              <li>Useful for overgrown acreage</li>
              <li>Effective for trails and fence lines</li>
              <li>Leaves processed organic material onsite</li>
              <li>May reduce hauling and debris piles</li>
              <li>Supports selective clearing</li>
            </ul>
          </div>
        </div>
        <p class="compare-note">
          The most appropriate method depends on vegetation size, terrain, access, intended land
          use and the equipment available from the contractor.
        </p>
        <p class="compare-cta">
          <a class="btn btn-orange" href="/request-estimate/" data-track="request_estimate_click" data-track-label="comparison">Describe Your Clearing Project</a>
        </p>
      </section>

      <!-- 6 · ACREAGE SERVICES -->
      <section class="section section--cream" id="acreage-services">
        <div class="section-heading">
          <h2>Clearing Solutions for Rural and Acreage Properties</h2>
        </div>
        <div class="acreage-grid">
          {acreageServices.map((s) => (
            <a class="card acreage-card" href={s.href}>
              <h3>{s.name}</h3>
              <p>{s.copy}</p>
            </a>
          ))}
        </div>
        <p class="availability-note">
          Service availability depends on project location, equipment requirements and contractor
          capability.
        </p>
      </section>

      <!-- 7 · PROCESS -->
      <section class="section" id="process">
        <div class="section-heading">
          <h2>How to Request Land-Clearing Service</h2>
        </div>
        <ol class="process-steps">
          <li>
            <span class="step-num" aria-hidden="true">1</span>
            <h3>Describe the Property</h3>
            <p>Provide the property location, approximate acreage, terrain, vegetation and intended use.</p>
          </li>
          <li>
            <span class="step-num" aria-hidden="true">2</span>
            <h3>Add Photographs</h3>
            <p>Upload wide property views, access points, vegetation, slopes, fences, structures and visible obstacles.</p>
          </li>
          <li>
            <span class="step-num" aria-hidden="true">3</span>
            <h3>Get Connected</h3>
            <p>The project information is reviewed and may be routed to a local contractor whose equipment, availability and service coverage fit the request.</p>
          </li>
          <li>
            <span class="step-num" aria-hidden="true">4</span>
            <h3>Discuss Scope &amp; Estimate</h3>
            <p>The contractor determines site access, equipment needs, project scope, scheduling and pricing.</p>
          </li>
        </ol>
        <p class="disclosure-note">{PROCESS_DISCLOSURE}</p>
      </section>

      <!-- 8 · CHECKLIST -->
      <section class="section section--cream" id="checklist">
        <div class="section-heading">
          <h2>Information That Helps Contractors Evaluate Your Project</h2>
        </div>
        <ul class="check-grid">
          {checklist.map((c) => (
            <li>{c}</li>
          ))}
        </ul>
      </section>
    </div>

    <!-- Desktop sidebar form (sticky through the upper page) -->
    <aside class="home-sidebar">
      <div class="sidebar-sticky">
        <LeadForm idPrefix="home-d" />
      </div>
    </aside>
  </div>

  <!-- 9 · PROJECT EXAMPLES -->
  <section class="section" id="examples">
    <div class="container">
      <div class="section-heading">
        <h2>Common Land-Clearing Project Types</h2>
        <p>
          Illustrations of typical project categories across the region. Verified contractor
          photographs will replace these examples as they are supplied.
        </p>
      </div>
      <div class="gallery-grid">
        {gallery.map((g) => (
          <figure class="card gallery-item">
            <img src={g.img} alt={g.alt} width="400" height="230" loading="lazy" />
            <figcaption>{g.label}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- 10 · SERVICE AREA -->
  <section class="section section--cream" id="service-area">
    <div class="container area-grid">
      <div class="area-copy">
        <h2>Land Clearing Across Upper Cumberland</h2>
        <dl class="area-list">
          <dt>Primary Areas</dt>
          <dd>Cookeville (Putnam County) · Crossville (Cumberland County)</dd>
          <dt>Secondary Areas</dt>
          <dd>Sparta (White County) · Livingston (Overton County) · Smithville (DeKalb County)</dd>
          <dt>Surrounding Communities</dt>
          <dd>Baxter · Monterey · Algood &amp; nearby rural areas</dd>
        </dl>
        <p>
          Property location, contractor coverage, access and project scope may affect availability.
          Submit the property address or nearest road to check whether a project can be reviewed.
        </p>
        <a class="btn btn-orange" href="/request-estimate/" data-track="request_estimate_click" data-track-label="service_area">Check Your Property Location</a>
        <p class="area-more"><a href="/service-area/">View the full Upper Cumberland service area →</a></p>
      </div>
      <ServiceAreaMap />
    </div>
  </section>

  <!-- 11 · FAQ -->
  <FaqAccordion faqs={homeFaqs} heading="Land-Clearing Questions" />

  <!-- 12 · FINAL CTA -->
  <CtaBand />
</BaseLayout>

<style>
  /* ── Hero ── */
  .hero {
    position: relative;
    background: var(--green-dark);
    color: var(--white);
    overflow: hidden;
  }
  .hero-media {
    position: absolute;
    inset: 0;
    background: url('/images/hero-forestry-mulcher.svg') center/cover no-repeat;
  }
  .hero-media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(15, 45, 24, 0.94) 0%, rgba(15, 45, 24, 0.82) 45%, rgba(15, 45, 24, 0.25) 100%);
  }
  .hero-inner { position: relative; padding-block: clamp(3rem, 8vw, 5.5rem); }
  .hero-copy { max-width: 620px; }
  .hero-eyebrow {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 2.5px;
    font-size: 0.9rem;
    color: var(--orange);
    margin-bottom: 0.75rem;
  }
  .hero h1 { color: var(--white); margin-bottom: 1rem; }
  .hero-h1-main { display: block; font-size: clamp(2.2rem, 5.5vw, 3.6rem); line-height: 1.05; }
  .hero-h1-sub {
    display: block;
    font-size: clamp(1rem, 2vw, 1.35rem);
    font-weight: 500;
    letter-spacing: 3px;
    color: #cfd6c5;
    margin-top: 0.5rem;
  }
  .hero-text { font-size: 1.08rem; color: #e4e8da; max-width: 54ch; }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1.5rem; }
  .hero-points { position: relative; background: rgba(15, 45, 24, 0.85); border-top: 1px solid rgba(255, 255, 255, 0.15); }
  .hero-points-inner {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    padding-block: 0.8rem;
    font-family: var(--font-display);
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .hero-points-inner span::before { content: '✓ '; color: var(--orange); }

  /* ── Qualification bar ── */
  .qual-bar { background: var(--cream); border-bottom: 1px solid var(--border); }
  .qual-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding-block: 1rem;
  }
  .qual-questions {
    display: flex;
    gap: 1.75rem;
    flex-wrap: wrap;
    list-style: none;
    margin: 0;
    padding: 0;
    font-weight: 600;
    font-size: 0.92rem;
  }
  .qual-questions li::before { content: ''; display: inline-block; width: 9px; height: 9px; border-radius: 50%; background: var(--orange); margin-right: 0.5rem; }

  /* ── Home grid with sidebar ── */
  .home-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 380px;
    gap: 2.5rem;
    align-items: start;
  }
  .home-main { min-width: 0; }
  .home-main .section--cream {
    border-radius: var(--radius);
    padding-inline: clamp(1rem, 3vw, 2rem);
  }
  .sidebar-sticky { position: sticky; top: 90px; padding-block: 2.5rem; }
  .mobile-form { display: none; }
  @media (max-width: 980px) {
    .home-grid { grid-template-columns: 1fr; }
    .home-sidebar { display: none; }
    .mobile-form { display: block; margin-block: 1rem 2rem; scroll-margin-top: 90px; }
  }
  @media (min-width: 981px) {
    /* On desktop, #home-form anchor lives in hidden mobile block — send clicks to sidebar instead */
    .mobile-form { position: absolute; }
  }

  /* ── Service cards ── */
  .service-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: 1.25rem;
  }
  .service-card img { aspect-ratio: 400 / 230; object-fit: cover; }
  .service-card-body { padding: 1rem 1.1rem 1.2rem; }
  .service-card-body p { font-size: 0.9rem; color: var(--text-muted); }
  .service-card-body a { font-weight: 600; font-size: 0.92rem; text-decoration: none; color: var(--orange-dark); }
  .service-card-body a:hover { text-decoration: underline; }

  /* ── Project types ── */
  .type-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1rem;
  }
  .type-card { display: block; padding: 1.1rem 1.2rem; text-decoration: none; }
  .type-card h3 { font-size: 1.05rem; color: var(--green-deep); }
  .type-card p { font-size: 0.88rem; color: var(--text-muted); margin: 0; }

  /* ── Comparison ── */
  .compare-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .compare-col {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.4rem 1.5rem;
    background: var(--white);
  }
  .compare-col--alt { background: var(--cream); border-color: var(--olive); }
  .compare-col ul { margin: 0; padding-left: 0; list-style: none; }
  .compare-col li { padding-left: 1.4em; position: relative; margin-bottom: 0.5rem; }
  .compare-col li::before { content: '✓'; position: absolute; left: 0; color: var(--orange); font-weight: 700; }
  .compare-note { margin-top: 1.25rem; font-size: 0.88rem; color: var(--text-muted); text-align: center; }
  .compare-cta { text-align: center; margin-top: 0.5rem; }
  @media (max-width: 700px) {
    .compare-grid { grid-template-columns: 1fr; }
  }

  /* ── Acreage blocks ── */
  .acreage-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }
  .acreage-card { display: block; padding: 1.1rem 1.2rem; text-decoration: none; }
  .acreage-card h3 { font-size: 1rem; color: var(--green-deep); }
  .acreage-card p { font-size: 0.86rem; color: var(--text-muted); margin: 0; }
  .availability-note { margin-top: 1rem; font-size: 0.85rem; color: var(--text-muted); text-align: center; }

  /* ── Process ── */
  .process-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: step;
  }
  .process-steps h3 { font-size: 1.02rem; }
  .process-steps p { font-size: 0.88rem; color: var(--text-muted); margin: 0; }
  .step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--green-deep);
    color: var(--white);
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
  }
  .process-steps + .disclosure-note { margin-top: 1.5rem; }
  @media (max-width: 900px) {
    .process-steps { grid-template-columns: 1fr; }
  }

  /* ── Checklist ── */
  .check-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 820px;
    margin-inline: auto;
  }
  .check-grid li { padding-left: 1.5em; position: relative; }
  .check-grid li::before { content: '✓'; position: absolute; left: 0; color: var(--orange); font-weight: 700; }
  @media (max-width: 620px) {
    .check-grid { grid-template-columns: 1fr; }
  }

  /* ── Gallery ── */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.25rem;
  }
  .gallery-item { margin: 0; }
  .gallery-item img { aspect-ratio: 400 / 230; object-fit: cover; }
  .gallery-item figcaption {
    padding: 0.7rem 1rem;
    font-family: var(--font-display);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-size: 0.9rem;
  }

  /* ── Service area ── */
  .area-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  .area-list dt {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 0.85rem;
    color: var(--green-deep);
    margin-top: 0.8rem;
  }
  .area-list dd { margin: 0.15rem 0 0; font-weight: 600; }
  .area-more { margin-top: 1rem; font-size: 0.92rem; }
  @media (max-width: 860px) {
    .area-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  // On desktop the inline mobile form is hidden — route the qualification-bar
  // anchor to the sidebar form instead so the smooth scroll lands somewhere visible.
  document.querySelector('.qual-inner a')?.addEventListener('click', (e) => {
    const sidebar = document.querySelector<HTMLElement>('.home-sidebar');
    if (sidebar && getComputedStyle(sidebar).display !== 'none') {
      e.preventDefault();
      sidebar.scrollIntoView({ behavior: 'smooth', block: 'start' });
      sidebar.querySelector<HTMLInputElement>('input')?.focus({ preventScroll: true });
    }
  });
</script>
