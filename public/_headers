# Security + caching headers for Cloudflare Pages static responses.
# Note: preview-deployment noindex is handled dynamically in functions/_middleware.ts
# because _headers cannot vary by environment.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com https://www.googletagmanager.com https://www.google-analytics.com; frame-src https://challenges.cloudflare.com; img-src 'self' data: https://www.google-analytics.com; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self' https://challenges.cloudflare.com https://www.google-analytics.com https://region1.google-analytics.com; base-uri 'self'; form-action 'self'; object-src 'none'

# Fingerprinted build assets are safe to cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts are fingerprinted by the build as well; static logo/images are not,
# so give them a modest cache and let Cloudflare revalidate.
/images/*
  Cache-Control: public, max-age=86400
/logos/*
  Cache-Control: public, max-age=86400
